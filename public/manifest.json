{
  "manifest_version": 3,
  "name": "LocalNotes",
  "version": "0.1.0",
  "description": "A local-first notes app — notes live in your browser, never in the cloud.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "LocalNotes — open a new tab"
  }
}
